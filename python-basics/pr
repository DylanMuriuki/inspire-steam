import tkinter as tk
from tkinter import messagebox, filedialog

# List to store students
students = []

# Function to add student
def add_student():
    student_id = entry_id.get()
    first_name = entry_first.get()
    last_name = entry_last.get()
    courses = entry_courses.get()
    phone = entry_phone.get()

    if student_id == "" or first_name == "" or last_name == "":
        messagebox.showerror("Error", "Please fill all required fields!")
        return

    student = {
        "ID": student_id,
        "First Name": first_name,
        "Last Name": last_name,
        "Courses": courses,
        "Phone": phone
    }

    students.append(student)

    listbox.insert(tk.END, f"{student_id} - {first_name} {last_name}")

    clear_fields()
    messagebox.showinfo("Success", "Student Added Successfully!")

# Function to clear fields
def clear_fields():
    entry_id.delete(0, tk.END)
    entry_first.delete(0, tk.END)
    entry_last.delete(0, tk.END)
    entry_courses.delete(0, tk.END)
    entry_phone.delete(0, tk.END)

# Function to export students to text file
def export_students():
    if not students:
        messagebox.showwarning("Warning", "No students to export!")
        return

    file = filedialog.asksaveasfilename(defaultextension=".txt",
                                        filetypes=[("Text Files", "*.txt")])
    if file:
        with open(file, "w") as f:
            for student in students:
                f.write(f"ID: {student['ID']}\n")
                f.write(f"Name: {student['First Name']} {student['Last Name']}\n")
                f.write(f"Courses: {student['Courses']}\n")
                f.write(f"Phone: {student['Phone']}\n")
                f.write("-" * 30 + "\n")
        messagebox.showinfo("Exported", "Students exported successfully!")

# Create main window
root = tk.Tk()
root.title("School Management System")
root.geometry("500x500")

# Labels and Entry fields
tk.Label(root, text="Student ID").pack()
entry_id = tk.Entry(root)
entry_id.pack()

tk.Label(root, text="First Name").pack()
entry_first = tk.Entry(root)
entry_first.pack()

tk.Label(root, text="Last Name").pack()
entry_last = tk.Entry(root)
entry_last.pack()

tk.Label(root, text="Courses (comma separated)").pack()
entry_courses = tk.Entry(root)
entry_courses.pack()

tk.Label(root, text="Phone Number").pack()
entry_phone = tk.Entry(root)
entry_phone.pack()

# Buttons
tk.Button(root, text="Add Student", command=add_student).pack(pady=5)
tk.Button(root, text="Export to Text File", command=export_students).pack(pady=5)

# Listbox to display students
tk.Label(root, text="Students List").pack()
listbox = tk.Listbox(root, width=50)
listbox.pack(pady=10)

root.mainloop()